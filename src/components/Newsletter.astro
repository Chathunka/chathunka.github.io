<section class="newsletter-section">
  <div>
    <span class="eyebrow">Newsletter</span>
    <h2>Engineering notes for systems that meet the physical world.</h2>
    <p>Monthly deep dives on embedded systems, edge AI, robotics, Linux, electronics, and field-ready software.</p>
  </div>
  <form class="newsletter-form" name="newsletter" method="post" data-netlify="true">
    <label for="email">Email address</label>
    <div>
      <input id="email" name="email" type="email" placeholder="engineer@example.com" autocomplete="email" />
      <button type="submit">Subscribe</button>
    </div>
  </form>
</section>
